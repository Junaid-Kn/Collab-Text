{
  "name": "collaborative-text-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "server": "tsx src/server/server.ts",
    "dev:all": "npm run server & npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test src/lib/yata/yata-sequence.test.ts",
    "test:integration": "tsx scripts/yata-integration-test.ts",
    "cassandra:schema": "docker exec -i cassandra1 cqlsh < scripts/cassandra-schema.cql",
    "cassandra:migrate": "docker exec -i cassandra1 cqlsh < scripts/cassandra-migrate-crdt.cql"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cassandra-driver": "^4.9.0",
    "dgram": "^1.0.1",
    "dns": "^0.2.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
